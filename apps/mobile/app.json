{
  "expo": {
    "name": "MyBudget",
    "slug": "mybudgetapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mybudget",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mybudgetapp.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture receipt photos",
        "NSPhotoLibraryUsageDescription": "Used to select receipt images",
        "NSFaceIDUsageDescription": "Used to securely unlock the app"
      }
    },
    "android": {
      "package": "com.mybudgetapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MyBudget to access your camera to capture receipts."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow MyBudget to use Face ID to unlock the app."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
